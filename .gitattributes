# Normalize line endings to LF (Unix) for cross-platform / WSL
* text=auto eol=lf

# Source code
*.rs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf

# Binary files - do not touch
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.so binary
*.dll binary
*.exe binary
