{
  "name": "sol-marketplace",
  "version": "1.0.0",
  "description": "A decentralized job marketplace platform built on Solana blockchain.",
  "private": true,
  "scripts": {
    "prepare": "simple-git-hooks",
    "dev": "concurrently \"npm run dev:app\" \"npm run dev:server\"",
    "dev:app": "cd app && npm run dev",
    "dev:server": "cd server && npm run dev"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "simple-git-hooks": "^2.9.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vladyweb3ai/sol-marketplace.git"
  },
  "homepage": "https://github.com/vladyweb3ai/sol-marketplace#readme",
  "dependencies": {
    "react-hot-toast": "^2.6.0"
  }
}
