    "/api/verify-tx": {
      "post": {
        "tags": [
          "verifyTx"
        ],
        "summary": "Verify a Solana Devnet transaction",
        "description": "Accepts a transaction signature. Fetches the transaction from Solana Devnet and confirms: (1) it exists, (2) status is successful (meta.err === null), (3) the expected wallet address is involved in the account keys.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["signature"],
                "properties": {
                  "signature": {
                    "type": "string",
                    "description": "Base58-encoded Solana transaction signature",
                    "example": "5UfgJ5vVZxUxefDGqzqkVLHzHxVTyYH9StYyHKGSzYk5xPbdjCGbGmWz74arTm5JnYSMNXByBMJxmvqrdLXbmPz"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction found — returns verification result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "transactionFound": { "type": "boolean" },
                    "status": { "type": "string", "enum": ["success", "failed"] },
                    "walletMatched": { "type": "boolean" }
                  }
                },
                "examples": {
                  "success": {
                    "summary": "All conditions met",
                    "value": {
                      "success": true,
                      "transactionFound": true,
                      "status": "success",
                      "walletMatched": true
                    }
                  },
                  "failed": {
                    "summary": "Transaction failed on-chain",
                    "value": {
                      "success": false,
                      "transactionFound": true,
                      "status": "failed",
                      "walletMatched": false
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing or invalid signature",
            "content": {
              "application/json": {
                "example": {
                  "success": false,
                  "transactionFound": false,
                  "message": "Missing or invalid \"signature\" field"
                }
              }
            }
          },
          "404": {
            "description": "Transaction not found on Devnet",
            "content": {
              "application/json": {
                "example": {
                  "success": false,
                  "transactionFound": false,
                  "status": "not_found",
                  "walletMatched": false
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    }
